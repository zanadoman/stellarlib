{
  "version": 8,
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "linux-host",
      "hidden": true,
      "inherits": "default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x86_64-linux-gnu",
      "hidden": true,
      "inherits": "linux-host",
      "toolchainFile": "${sourceDir}/cmake/x86_64-linux-gnu.cmake"
    },
    {
      "name": "aarch64-linux-gnu",
      "hidden": true,
      "inherits": "linux-host",
      "toolchainFile": "${sourceDir}/cmake/aarch64-linux-gnu.cmake"
    },
    {
      "name": "x86_64-w64-mingw32",
      "hidden": true,
      "inherits": "linux-host",
      "toolchainFile": "${sourceDir}/cmake/x86_64-w64-mingw32.cmake"
    },
    {
      "name": "x86_64-linux-android",
      "hidden": true,
      "inherits": "linux-host",
      "toolchainFile": "${sourceDir}/cmake/x86_64-linux-android.cmake"
    },
    {
      "name": "aarch64-linux-android",
      "hidden": true,
      "inherits": "linux-host",
      "toolchainFile": "${sourceDir}/cmake/aarch64-linux-android.cmake"
    },
    {
      "name": "riscv64-linux-android",
      "hidden": true,
      "inherits": "linux-host",
      "toolchainFile": "${sourceDir}/cmake/riscv64-linux-android.cmake"
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "vendored",
      "hidden": true,
      "cacheVariables": {
        "STELLARLIB_VENDORED": "ON"
      }
    },
    {
      "name": "x86_64-linux-gnu-debug",
      "inherits": ["x86_64-linux-gnu", "debug"],
      "binaryDir": "${sourceDir}/build/x86_64-linux-gnu/debug"
    },
    {
      "name": "x86_64-linux-gnu-debug-vendored",
      "inherits": ["x86_64-linux-gnu-debug", "vendored"]
    },
    {
      "name": "x86_64-linux-gnu-release",
      "inherits": ["x86_64-linux-gnu", "release"],
      "binaryDir": "${sourceDir}/build/x86_64-linux-gnu/release"
    },
    {
      "name": "x86_64-linux-gnu-release-vendored",
      "inherits": ["x86_64-linux-gnu-release", "vendored"]
    },
    {
      "name": "aarch64-linux-gnu-debug",
      "inherits": ["aarch64-linux-gnu", "debug"],
      "binaryDir": "${sourceDir}/build/aarch64-linux-gnu/debug"
    },
    {
      "name": "aarch64-linux-gnu-debug-vendored",
      "inherits": ["aarch64-linux-gnu-debug", "vendored"]
    },
    {
      "name": "aarch64-linux-gnu-release",
      "inherits": ["aarch64-linux-gnu", "release"],
      "binaryDir": "${sourceDir}/build/aarch64-linux-gnu/release"
    },
    {
      "name": "aarch64-linux-gnu-release-vendored",
      "inherits": ["aarch64-linux-gnu-release", "vendored"]
    },
    {
      "name": "x86_64-w64-mingw32-debug",
      "inherits": ["x86_64-w64-mingw32", "debug"],
      "binaryDir": "${sourceDir}/build/x86_64-w64-mingw32/debug"
    },
    {
      "name": "x86_64-w64-mingw32-debug-vendored",
      "inherits": ["x86_64-w64-mingw32-debug", "vendored"]
    },
    {
      "name": "x86_64-w64-mingw32-release",
      "inherits": ["x86_64-w64-mingw32", "release"],
      "binaryDir": "${sourceDir}/build/x86_64-w64-mingw32/release"
    },
    {
      "name": "x86_64-w64-mingw32-release-vendored",
      "inherits": ["x86_64-w64-mingw32-release", "vendored"]
    },
    {
      "name": "x86_64-linux-android-debug",
      "inherits": ["x86_64-linux-android", "debug"],
      "binaryDir": "${sourceDir}/build/x86_64-linux-android/debug"
    },
    {
      "name": "x86_64-linux-android-debug-vendored",
      "inherits": ["x86_64-linux-android-debug", "vendored"]
    },
    {
      "name": "x86_64-linux-android-release",
      "inherits": ["x86_64-linux-android", "release"],
      "binaryDir": "${sourceDir}/build/x86_64-linux-android/release"
    },
    {
      "name": "x86_64-linux-android-release-vendored",
      "inherits": ["x86_64-linux-android-release", "vendored"]
    },
    {
      "name": "aarch64-linux-android-debug",
      "inherits": ["aarch64-linux-android", "debug"],
      "binaryDir": "${sourceDir}/build/aarch64-linux-android/debug"
    },
    {
      "name": "aarch64-linux-android-debug-vendored",
      "inherits": ["aarch64-linux-android-debug", "vendored"]
    },
    {
      "name": "aarch64-linux-android-release",
      "inherits": ["aarch64-linux-android", "release"],
      "binaryDir": "${sourceDir}/build/aarch64-linux-android/release"
    },
    {
      "name": "aarch64-linux-android-release-vendored",
      "inherits": ["aarch64-linux-android-release", "vendored"]
    },
    {
      "name": "riscv64-linux-android-debug",
      "inherits": ["riscv64-linux-android", "debug"],
      "binaryDir": "${sourceDir}/build/riscv64-linux-android/debug"
    },
    {
      "name": "riscv64-linux-android-debug-vendored",
      "inherits": ["riscv64-linux-android-debug", "vendored"]
    },
    {
      "name": "riscv64-linux-android-release",
      "inherits": ["riscv64-linux-android", "release"],
      "binaryDir": "${sourceDir}/build/riscv64-linux-android/release"
    },
    {
      "name": "riscv64-linux-android-release-vendored",
      "inherits": ["riscv64-linux-android-release", "vendored"]
    }
  ]
}
